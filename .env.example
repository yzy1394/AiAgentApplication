# Runtime profile
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080
SERVER_CONTEXT_PATH=/api

# Model / search keys
ALI_DASHSCOPE_API_KEY=
# Optional fallback alias used by local profile
DASHSCOPE_API_KEY=
SEARCH_API_KEY=

# Database
MYSQL_URL=jdbc:mysql://<host>:3306/ai_agent?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai
MYSQL_USERNAME=
MYSQL_PASSWORD=

# CORS (comma-separated)
APP_CORS_ALLOWED_ORIGIN_PATTERNS=https://your-frontend-domain.com

# Keep risky tools disabled in production
APP_TOOLS_TERMINAL_ENABLED=false
APP_TOOLS_FILE_ENABLED=false
